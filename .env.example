# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MISTRAL_API_KEY=your_mistral_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM settings
LLM_MODEL=mistral-medium-latest
LLM_FALLBACK_MODEL=gpt-4o-mini

# Ollama (раскомментировать если используешь локальный Qwen вместо OpenAI fallback)
# LLM_FALLBACK_MODEL=qwen3.5:9b
# OLLAMA_BASE_URL=http://ollama:11434

# Session storage
SESSION_DIR=/app/data/sessions
SESSION_TTL_DAYS=7
SESSION_SALT=change-this-to-a-random-secret

# Limits
RATE_LIMIT_RPM=5
MAX_FILE_SIZE_MB=50
LLM_MAX_STEPS=10
CONVERSATION_HISTORY_LIMIT=8

# Logging
LOG_LEVEL=INFO

# Langfuse трейсинг (опционально — https://langfuse.com или self-hosted)
# Получи ключи на cloud.langfuse.com → Settings → API Keys
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
